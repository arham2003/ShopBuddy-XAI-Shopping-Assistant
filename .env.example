# Root environment template for quick reference.
# Primary backend runtime variables are in backend/.env.example.
# Frontend runtime variables are in frontend/.env.example.

# ---- Backend required ----
GOOGLE_API_KEY="your_google_api_key_here"
GROQ_API_KEY="your_groq_api_key_here"
EXCHANGE_RATE_API_KEY="your_exchange_rate_api_key_here"
DATABASE_URL="your_supabase_postgres_connection_string_here"

# ---- Frontend optional override ----
VITE_API_URL="http://localhost:8000"
