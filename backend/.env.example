# Google Gemini API key (required)
GOOGLE_API_KEY="your_google_api_key_here"

# Groq API key (optional if using Groq models in UI)
GROQ_API_KEY="your_groq_api_key_here"

# ExchangeRate-API key (required for currency normalization)
EXCHANGE_RATE_API_KEY="your_exchange_rate_api_key_here"

# Supabase Postgres connection string (required)
# Example format:
# postgresql://postgres:password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres
DATABASE_URL="your_supabase_postgres_connection_string_here"
